{
  "name": "@mfjjs/ruflo-setup",
  "version": "0.2.13",
  "description": "Cross-platform setup CLI for Ruflo + Claude Flow projects",
  "type": "module",
  "bin": {
    "ruflo-setup": "./bin/ruflo-setup.js"
  },
  "files": [
    "bin",
    "src",
    "templates",
    "CHANGELOG.md",
    "docs/ruflo-benefits.md",
    "claude-hooks"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "lint": "node --check ./src/cli.js && node --check ./src/setup.js && node --check ./src/hooks.js && node --check ./src/utils.js && node --check ./bin/ruflo-setup.js",
    "test": "node --test tests/cli.test.mjs",
    "test:cli": "node ./bin/ruflo-setup.js --dry-run --skip-init --no-hooks --yes",
    "pack:dry": "pnpm pack --json",
    "publish:all": "pnpm publish && pnpm publish --prefix ruflo-setup"
  },
  "keywords": [
    "ruflo",
    "claude-flow",
    "cli",
    "setup"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "http:s://github.com/mfjassociates/ruflo-setup.git"
  },
  "bugs": {
    "url": "https://github.com/mfjassociates/ruflo-setup/issues"
  },
  "homepage": "https://github.com/mfjassociates/ruflo-setup#readme",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
